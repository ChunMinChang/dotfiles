# Windows / Git Bash settings
# ====================================================================
# Loaded by dot.bashrc when running under MINGW/MSYS/Cygwin
# (e.g. mozilla-build's MSYS2 shell, Git Bash, Cygwin).

# Git
# ====================================================================
if CommandExists git; then
  if [ -r "$HOME/.gitconfig" ]; then
    BranchInPrompt
  else
    echo Please set .gitconfig first
  fi
else
  echo Please install git before loading its settings.
fi

# Make MSYS create native NTFS symlinks instead of failing with
# "Operation not permitted" — needed for `git worktree add` (and `ln
# -s`, etc.) when the branch tracks symlink-typed entries (mode
# 120000) such as `.claude/skills/*`. Requires Windows Developer Mode
# (or Administrator); harmless if neither is available — strict mode
# will surface a real error instead of silently copying. Append the
# token instead of overwriting so any other tokens (e.g. enable_pcon
# from Git for Windows) survive.
case "${MSYS:-}" in
  *winsymlinks:*) ;;  # Already configured — leave it alone.
  "") export MSYS="winsymlinks:nativestrict" ;;
  *) export MSYS="$MSYS winsymlinks:nativestrict" ;;
esac

if CommandExists vim; then
  export GIT_EDITOR=vim
fi

# platform-dependent paths
# ====================================================================
# Source configuration for configurable paths
if [ -r "$DOTFILES/config.sh" ]; then
  # shellcheck source=config.sh
  . "$DOTFILES/config.sh"
fi

# Trash dir: the Recycle Bin isn't directly mountable, so default to a
# regular directory under $HOME. Override via DOTFILES_TRASH_DIR_WINDOWS.
TRASH="${DOTFILES_TRASH_DIR:-$HOME/.Trash}"

# Add tool dirs that Windows installers populate but that are NOT on
# the default Git Bash PATH:
#   - pip3 --user puts binaries in %APPDATA%\Python\PythonXX\Scripts
#   - npm -g puts binaries in %APPDATA%\npm
# Without these, freshly-installed ruff / black / markdownlint etc.
# aren't reachable from Git Bash even though pip/npm reported success.
for _scripts_dir in "$HOME"/AppData/Roaming/Python/Python*/Scripts; do
  [ -d "$_scripts_dir" ] && PATH="$_scripts_dir:$PATH"
done
unset _scripts_dir
[ -d "$HOME/AppData/Roaming/npm" ] && PATH="$HOME/AppData/Roaming/npm:$PATH"
export PATH
