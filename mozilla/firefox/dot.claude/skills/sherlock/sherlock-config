#!/usr/bin/env python3
"""Sherlock configuration and bug-fetching helper.

Checks prerequisites, resolves API keys, and fetches bug data from
Bugzilla (via bmo-to-md or direct REST API fallback).

Usage:
    sherlock-config --check-setup
    sherlock-config --check-auth
    sherlock-config --get-output-dir
    sherlock-config --get-patch-author
    sherlock-config --fetch-bug <bug_id> -o <dir>
    sherlock-config --fetch-attachments <bug_id> -o <dir>

API key resolution (first match wins):
    1. api_key in ~/.config/sherlock/config.toml
    2. $BMO_API_KEY environment variable
    3. api_key in ~/.config/bugzilla/config.toml
    4. api_key in ~/.config/bmo-to-md/config.toml
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import urllib.error
import urllib.request

BMO = "https://bugzilla.mozilla.org"
SHERLOCK_CONFIG = os.path.expanduser("~/.config/sherlock/config.toml")
BMO_CONFIG = os.path.expanduser("~/.config/bugzilla/config.toml")
BMO_TO_MD_CONFIG = os.path.expanduser("~/.config/bmo-to-md/config.toml")


# ---------------------------------------------------------------------------
# TOML helpers (stdlib-only, minimal parser)
# ---------------------------------------------------------------------------

def _read_toml_api_key(path):
    """Read api_key from a TOML file.  Returns the value or None."""
    if not os.path.isfile(path):
        return None
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line.startswith("api_key"):
                    _, _, val = line.partition("=")
                    val = val.strip().strip('"').strip("'")
                    if val:
                        return val
    except OSError:
        pass
    return None


def _read_toml_field(path, field):
    """Read an arbitrary top-level field from a TOML file."""
    if not os.path.isfile(path):
        return None
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line.startswith(field):
                    _, _, val = line.partition("=")
                    val = val.strip().strip('"').strip("'")
                    if val:
                        return val
    except OSError:
        pass
    return None


# ---------------------------------------------------------------------------
# API key resolution
# ---------------------------------------------------------------------------

def resolve_api_key():
    """Resolve BMO API key without ever printing it.

    Checks, in order:
      1. api_key in ~/.config/sherlock/config.toml
      2. $BMO_API_KEY environment variable
      3. api_key in ~/.config/bugzilla/config.toml
      4. api_key in ~/.config/bmo-to-md/config.toml
    Returns (key, source) or (None, None).
    """
    val = _read_toml_api_key(SHERLOCK_CONFIG)
    if val:
        return val, SHERLOCK_CONFIG

    env = os.environ.get("BMO_API_KEY", "").strip()
    if env:
        return env, "$BMO_API_KEY"

    for path in (BMO_CONFIG, BMO_TO_MD_CONFIG):
        val = _read_toml_api_key(path)
        if val:
            return val, path

    return None, None


def require_api_key():
    """Return the API key or exit with an error."""
    key, source = resolve_api_key()
    if not key:
        print("error: no Bugzilla API key found", file=sys.stderr)
        print(
            "Store your key in " + SHERLOCK_CONFIG
            + " as api_key, or set $BMO_API_KEY",
            file=sys.stderr,
        )
        sys.exit(1)
    return key, source


# ---------------------------------------------------------------------------
# Prerequisite checks
# ---------------------------------------------------------------------------

def _has_command(name):
    """Return True if *name* is on PATH."""
    return shutil.which(name) is not None


def check_auth():
    """Print whether an API key is available (never prints the key)."""
    key, source = resolve_api_key()
    if key:
        print(f"OK: API key found via {source}")
    else:
        print("No API key found")
        print(
            f"Store your key in {SHERLOCK_CONFIG} as api_key, "
            f"or set $BMO_API_KEY"
        )
        sys.exit(1)


def get_output_dir():
    """Print the configured output_dir from sherlock config, or empty."""
    val = _read_toml_field(SHERLOCK_CONFIG, "output_dir")
    print(val or "")


def get_patch_author():
    """Print the patch author for git commit --author.

    Resolution order:
      1. patch_author in ~/.config/sherlock/config.toml
      2. Git user config (git config user.name + user.email)
    Prints in "Name <email>" format suitable for --author.
    """
    val = _read_toml_field(SHERLOCK_CONFIG, "patch_author")
    if val:
        print(val)
        return

    # Fall back to git config
    try:
        name = subprocess.run(
            ["git", "config", "user.name"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
        email = subprocess.run(
            ["git", "config", "user.email"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
        if name and email:
            print(f"{name} <{email}>")
            return
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass

    print("")


def check_setup():
    """Check all prerequisites and report status."""
    ok = True

    # API key
    key, source = resolve_api_key()
    if key:
        print(f"OK: API key found via {source}")
    else:
        print("MISSING: No Bugzilla API key found")
        ok = False

    # bmo-to-md
    if _has_command("bmo-to-md"):
        print("OK: bmo-to-md is installed")
    else:
        print("MISSING: bmo-to-md not found on PATH (optional; REST API "
              "fallback will be used)")

    # searchfox-cli
    if _has_command("searchfox-cli"):
        print("OK: searchfox-cli is installed")
    else:
        print("MISSING: searchfox-cli not found on PATH")
        ok = False

    # output_dir
    out = _read_toml_field(SHERLOCK_CONFIG, "output_dir")
    if out:
        print(f"OK: output_dir = {out}")
    else:
        print("MISSING: output_dir not configured in " + SHERLOCK_CONFIG)
        ok = False

    if not ok:
        sys.exit(1)


# ---------------------------------------------------------------------------
# REST API helper
# ---------------------------------------------------------------------------

def _bmo_api_get(path, api_key):
    """GET a BMO REST endpoint and return parsed JSON."""
    url = f"{BMO}/rest/{path}"
    headers = {"Content-Type": "application/json"}
    if api_key:
        headers["X-BUGZILLA-API-KEY"] = api_key
    req = urllib.request.Request(url, headers=headers, method="GET")
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err_body = e.read().decode(errors="replace")
        print(
            f"error: GET /rest/{path} -> HTTP {e.code}\n{err_body}",
            file=sys.stderr,
        )
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"error: {e.reason}", file=sys.stderr)
        sys.exit(1)


# ---------------------------------------------------------------------------
# Bug fetching
# ---------------------------------------------------------------------------

def _bmo_to_md_has_own_key():
    """Return True if bmo-to-md's own config has an API key."""
    return _read_toml_api_key(BMO_TO_MD_CONFIG) is not None


def _run_bmo_to_md(bug_id, out_dir, extra_flags=None, api_key=None):
    """Run bmo-to-md, optionally injecting BMO_API_KEY into the env."""
    cmd = ["bmo-to-md", "-o", out_dir]
    if extra_flags:
        cmd.extend(extra_flags)
    cmd.append(str(bug_id))

    env = None
    if api_key:
        env = os.environ.copy()
        env["BMO_API_KEY"] = api_key

    try:
        subprocess.run(cmd, check=True, env=env)
    except subprocess.CalledProcessError as e:
        print(f"error: bmo-to-md exited with code {e.returncode}",
              file=sys.stderr)
        sys.exit(1)


def _render_bug_markdown(bug, comments):
    """Render bug data + comments as a simple markdown string."""
    b = bug
    lines = [
        f"# Bug {b['id']} - {b.get('summary', '')}",
        "",
        f"- **Product:** {b.get('product', '')}",
        f"- **Component:** {b.get('component', '')}",
        f"- **Status:** {b.get('status', '')}",
    ]
    if b.get("resolution"):
        lines.append(f"- **Resolution:** {b['resolution']}")
    lines.extend([
        f"- **Severity:** {b.get('severity', '')}",
        f"- **Priority:** {b.get('priority', '')}",
    ])
    if b.get("keywords"):
        lines.append(f"- **Keywords:** {', '.join(b['keywords'])}")
    if b.get("see_also"):
        lines.append(
            f"- **See Also:** {', '.join(b['see_also'])}"
        )
    if b.get("depends_on"):
        lines.append(
            f"- **Depends On:** "
            f"{', '.join(str(d) for d in b['depends_on'])}"
        )
    if b.get("blocks"):
        lines.append(
            f"- **Blocks:** "
            f"{', '.join(str(d) for d in b['blocks'])}"
        )
    if b.get("flags"):
        flag_strs = [
            f"{f['name']}{f['status']}" for f in b["flags"]
        ]
        lines.append(f"- **Flags:** {', '.join(flag_strs)}")

    lines.append("")
    lines.append("---")
    lines.append("")
    lines.append("## Comments")
    lines.append("")

    for c in comments:
        author = c.get("author", c.get("creator", "unknown"))
        time = c.get("creation_time", "")
        lines.append(f"### Comment {c.get('count', '?')} "
                      f"by {author} ({time})")
        lines.append("")
        lines.append(c.get("text", ""))
        lines.append("")

    return "\n".join(lines)


def fetch_bug(bug_id, out_dir):
    """Fetch bug report using bmo-to-md or REST API fallback."""
    os.makedirs(out_dir, exist_ok=True)

    has_bmo_to_md = _has_command("bmo-to-md")
    key, source = resolve_api_key()

    if has_bmo_to_md and _bmo_to_md_has_own_key():
        # bmo-to-md has its own key; run it directly
        print(f"Fetching bug {bug_id} via bmo-to-md (using its own config)")
        _run_bmo_to_md(bug_id, out_dir)
        return

    if has_bmo_to_md and key:
        # bmo-to-md installed but key elsewhere; inject via env
        print(f"Fetching bug {bug_id} via bmo-to-md "
              f"(key injected from {source})")
        _run_bmo_to_md(bug_id, out_dir, api_key=key)
        return

    if key:
        # No bmo-to-md; fall back to REST API
        print(f"Fetching bug {bug_id} via REST API "
              f"(key from {source})")
        fields = (
            "id,summary,status,resolution,component,product,"
            "severity,priority,keywords,see_also,depends_on,"
            "blocks,flags"
        )
        bug_data = _bmo_api_get(
            f"bug/{bug_id}?include_fields={fields}", api_key=key
        )
        bugs = bug_data.get("bugs", [])
        if not bugs:
            print(f"error: bug {bug_id} not found", file=sys.stderr)
            sys.exit(1)
        bug = bugs[0]

        comment_data = _bmo_api_get(
            f"bug/{bug_id}/comment", api_key=key
        )
        comments = (
            comment_data.get("bugs", {})
            .get(str(bug_id), {})
            .get("comments", [])
        )

        md = _render_bug_markdown(bug, comments)
        out_path = os.path.join(out_dir, f"bug-{bug_id}.md")
        with open(out_path, "w") as f:
            f.write(md)
        print(f"Wrote {out_path}")
        return

    # Neither bmo-to-md nor key available
    print("error: cannot fetch bug — no API key and bmo-to-md "
          "not installed", file=sys.stderr)
    print("", file=sys.stderr)
    print("Setup options:", file=sys.stderr)
    print(f"  1. Install bmo-to-md and configure its API key",
          file=sys.stderr)
    print(f"  2. Add api_key to {SHERLOCK_CONFIG}", file=sys.stderr)
    print(f"  3. Set $BMO_API_KEY environment variable", file=sys.stderr)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Attachment fetching
# ---------------------------------------------------------------------------

def fetch_attachments(bug_id, out_dir):
    """Fetch bug attachments using bmo-to-md or REST API fallback."""
    os.makedirs(out_dir, exist_ok=True)

    has_bmo_to_md = _has_command("bmo-to-md")
    key, source = resolve_api_key()

    if has_bmo_to_md:
        # bmo-to-md -a downloads attachments
        if _bmo_to_md_has_own_key():
            print(f"Fetching attachments for bug {bug_id} via bmo-to-md")
            _run_bmo_to_md(bug_id, out_dir, extra_flags=["-a"])
        elif key:
            print(f"Fetching attachments for bug {bug_id} via bmo-to-md "
                  f"(key injected from {source})")
            _run_bmo_to_md(bug_id, out_dir, extra_flags=["-a"],
                           api_key=key)
        else:
            print("error: bmo-to-md installed but no API key found",
                  file=sys.stderr)
            print(f"Store your key in {SHERLOCK_CONFIG} or set $BMO_API_KEY",
                  file=sys.stderr)
            sys.exit(1)
        return

    if not key:
        print("error: cannot fetch attachments — no API key and "
              "bmo-to-md not installed", file=sys.stderr)
        print("", file=sys.stderr)
        print("Setup options:", file=sys.stderr)
        print(f"  1. Install bmo-to-md and configure its API key",
              file=sys.stderr)
        print(f"  2. Add api_key to {SHERLOCK_CONFIG}", file=sys.stderr)
        print(f"  3. Set $BMO_API_KEY environment variable",
              file=sys.stderr)
        sys.exit(1)

    # REST API fallback: fetch attachment list and download each
    print(f"Fetching attachments for bug {bug_id} via REST API "
          f"(key from {source})")
    result = _bmo_api_get(f"bug/{bug_id}/attachment", api_key=key)
    attachments = result.get("bugs", {}).get(str(bug_id), [])

    if not attachments:
        print(f"No attachments found on bug {bug_id}")
        return

    count = 0
    for att in attachments:
        if att.get("is_obsolete"):
            continue

        att_id = att["id"]
        filename = att.get("file_name", f"attachment-{att_id}")
        summary = att.get("summary", "")

        # Fetch full attachment data (includes base64 content)
        att_detail = _bmo_api_get(
            f"bug/attachment/{att_id}", api_key=key
        )
        att_data = (
            att_detail.get("attachments", {})
            .get(str(att_id), {})
        )
        data_b64 = att_data.get("data", "")
        if not data_b64:
            print(f"  Skipping attachment {att_id} ({summary}): no data")
            continue

        import base64
        raw = base64.b64decode(data_b64)
        out_path = os.path.join(out_dir, filename)
        with open(out_path, "wb") as f:
            f.write(raw)
        print(f"  Saved {out_path} ({summary})")
        count += 1

    print(f"Downloaded {count} attachment(s) to {out_dir}")


# ---------------------------------------------------------------------------
# CLI entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--check-setup", action="store_true",
        help="Check all prerequisites and report status",
    )
    parser.add_argument(
        "--check-auth", action="store_true",
        help="Check if an API key is available (never prints the key)",
    )
    parser.add_argument(
        "--get-output-dir", action="store_true",
        help="Print the configured output_dir, or empty string",
    )
    parser.add_argument(
        "--get-patch-author", action="store_true",
        help="Print the patch author (from config or git config)",
    )
    parser.add_argument(
        "--fetch-bug", metavar="BUG_ID",
        help="Fetch bug report for the given bug ID",
    )
    parser.add_argument(
        "--fetch-attachments", metavar="BUG_ID",
        help="Fetch attachments for the given bug ID",
    )
    parser.add_argument(
        "-o", "--output-dir", metavar="DIR",
        help="Output directory for fetched data",
    )
    args = parser.parse_args()

    # Exactly one action required
    actions = [
        args.check_setup,
        args.check_auth,
        args.get_output_dir,
        args.get_patch_author,
        args.fetch_bug is not None,
        args.fetch_attachments is not None,
    ]
    if sum(actions) == 0:
        parser.print_help()
        sys.exit(1)
    if sum(actions) > 1:
        parser.error("specify exactly one action")

    if args.check_setup:
        check_setup()
        return

    if args.check_auth:
        check_auth()
        return

    if args.get_output_dir:
        get_output_dir()
        return

    if args.get_patch_author:
        get_patch_author()
        return

    if args.fetch_bug is not None:
        if not args.output_dir:
            parser.error("--fetch-bug requires -o/--output-dir")
        fetch_bug(args.fetch_bug, args.output_dir)
        return

    if args.fetch_attachments is not None:
        if not args.output_dir:
            parser.error("--fetch-attachments requires -o/--output-dir")
        fetch_attachments(args.fetch_attachments, args.output_dir)
        return


if __name__ == "__main__":
    main()
