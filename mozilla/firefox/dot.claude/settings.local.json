{
  "permissions": {
    "allow": [
      "Bash(./mach help:*)",
      "Bash(./mach vendor:*)",
      "Bash(.claude/hooks/should-format-lint.sh:*)",
      "Bash(.claude/skills/sherlock/sherlock-config:*)",
      "Bash(bmo-to-md:*)",
      "Bash(ls:*)",
      "Bash(moz-phab:*)",
      "Bash(python3 .claude/skills/sec-approval/bmo-sec-approval:*)",
      "Bash(python3 .claude/skills/uplift-request/bmo-uplift-request:*)",
      "Bash(searchfox-cli:*)"
    ]
  },
  "model": "opusplan",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "moz"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-lint.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-format.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
