# Enforce LF for all text files in this repo.
#
# `text=auto` lets git detect text vs binary; `eol=lf` forces LF in the
# working tree on checkout, regardless of the user's `core.autocrlf`.
# Critical for shell scripts (bash chokes on CRLF in some cases) and
# for files this repo links into other tools' config dirs.
* text=auto eol=lf

# Belt-and-braces for known text formats — also documents intent.
*.sh    text eol=lf
*.bash  text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.conf  text eol=lf
dot.*   text eol=lf

# Binary file types — never convert, never diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
